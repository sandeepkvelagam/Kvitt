# ===========================================
# Kvitt Backend Environment
# Copy to .env and fill in your values.
# See docs/SETUP_KEYS.md for where to get each key.
# ===========================================

# Database (MongoDB - legacy, will be replaced by Supabase PostgreSQL)
MONGO_URL=mongodb://localhost:27017
DB_NAME=Kvitt-database

# Supabase (Auth + PostgreSQL DB)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase PostgreSQL Direct Connection (for asyncpg)
# Get from: Supabase Dashboard → Project Settings → Database → Connection String (Direct)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_DB_URL=

# Database backend: mongodb (legacy) or postgres (new)
DATABASE_BACKEND=mongodb

# OpenAI (replaces EMERGENT_LLM_KEY)
OPENAI_API_KEY=sk-xxx

# Stripe (one secret for all webhook endpoints)
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# App URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Auth: leave empty for Supabase (JWT via JWKS). Legacy OAuth only.
AUTH_SERVICE_URL=

# CORS: origins allowed to call API. Use * for dev; list domains for prod.
CORS_ORIGINS=*

# Optional: Email (Resend)
RESEND_API_KEY=
SENDER_EMAIL=

# Optional: Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

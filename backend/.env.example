# Database (MongoDB until migration to Supabase PostgreSQL)
MONGO_URL=mongodb://localhost:27017
DB_NAME=oddside

# Supabase (Auth + future DB)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# OpenAI (replaces EMERGENT_LLM_KEY)
OPENAI_API_KEY=sk-xxx

# Stripe
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_WEBHOOK_SECRET_WALLET=whsec_xxx
STRIPE_WEBHOOK_SECRET_DEBT=whsec_xxx

# App URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Optional: Auth service (Supabase URL for OAuth session exchange)
AUTH_SERVICE_URL=

# Optional: Email (Resend)
RESEND_API_KEY=
SENDER_EMAIL=

# Optional: Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# Optional: CORS
CORS_ORIGINS=*

# ===========================================
# Kvitt Frontend Environment
# Copy to .env and fill in your values.
# See docs/SETUP_KEYS.md for where to get each key.
# ===========================================

# Backend API (production: kvitt.duckdns.org)
REACT_APP_BACKEND_URL=https://kvitt.duckdns.org

# Supabase (Auth)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key

# Dev server
WDS_SOCKET_PORT=443
ENABLE_HEALTH_CHECK=false
ENABLE_VISUAL_EDITS=false

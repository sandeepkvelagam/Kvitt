# ===========================================
# Kvitt Backend Environment
# Copy to .env and fill in your values.
# PostgreSQL (Supabase) only - MongoDB removed.
# See docs/SETUP_KEYS.md for where to get each key.
# ===========================================

# Supabase (Auth + PostgreSQL DB + Storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase PostgreSQL Direct Connection (for asyncpg)
# Get from: Supabase Dashboard → Project Settings → Database → Connection String (Direct)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_DB_URL=

# AI: OpenAI (Assistant, Whisper) + Claude (Orchestrator, Group Chat)
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# Stripe (payments + webhooks)
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# App URLs
APP_URL=https://kvitt.duckdns.org
FRONTEND_URL=https://kvitt.duckdns.org

# Auth: leave empty for Supabase (JWT via JWKS)
AUTH_SERVICE_URL=

# CORS: origins allowed to call API
CORS_ORIGINS=*

# Email (Resend)
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://kvitt.duckdns.org/spotify/callback

# Optional: Logging
# LOG_LEVEL=INFO

# ===========================================
# Ops Scheduler (Admin Dashboard Data)
# ===========================================
# Set to 1 to enable background agents that populate admin dashboard data:
# - Health Monitor (every 1 min): populates service_health_rollups, creates alerts
# - Security Watch (every 5 min): creates security-related alerts
# - Product Insights (every hour): creates product alerts
# - Executive Summary (daily): generates daily ops reports
# - Escalation Check (every 5 min): escalates unacknowledged alerts
#
# Without this enabled, the following admin dashboard sections will show no data:
# - Requests & Errors chart
# - p95 Latency chart
# - Active Alerts
# - Open Incidents
#
# For production/staging, set: ENABLE_OPS_SCHEDULER=1
ENABLE_OPS_SCHEDULER=0

# ===========================================
# Kvitt Backend Environment
# Copy to .env and fill in your values.
# See docs/SETUP_KEYS.md for where to get each key.
# ===========================================

# Database (MongoDB until migration to Supabase PostgreSQL)
MONGO_URL=mongodb://localhost:27017
DB_NAME=oddside

# Supabase (Auth + future DB)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# OpenAI (replaces EMERGENT_LLM_KEY)
OPENAI_API_KEY=sk-xxx

# Stripe
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_WEBHOOK_SECRET_WALLET=whsec_xxx
STRIPE_WEBHOOK_SECRET_DEBT=whsec_xxx

# App URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Auth: leave empty for Supabase (JWT via JWKS). Legacy OAuth only.
AUTH_SERVICE_URL=

# CORS: origins allowed to call API. Use * for dev; list domains for prod.
CORS_ORIGINS=*

# Optional: Email (Resend)
RESEND_API_KEY=
SENDER_EMAIL=

# Optional: Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

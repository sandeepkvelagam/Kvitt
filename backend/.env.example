# ===========================================
# Kvitt Backend Environment
# Copy to .env and fill in your values.
# PostgreSQL (Supabase) only - MongoDB removed.
# See docs/SETUP_KEYS.md for where to get each key.
# ===========================================

# Supabase (Auth + PostgreSQL DB)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase PostgreSQL Direct Connection (for asyncpg)
# Get from: Supabase Dashboard → Project Settings → Database → Connection String (Direct)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_DB_URL=

# AI: OpenAI (Assistant, Whisper) + Claude (Orchestrator, Group Chat)
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# Stripe (payments + webhooks)
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# App URLs
APP_URL=https://kvitt.duckdns.org
FRONTEND_URL=https://kvitt.duckdns.org

# Auth: leave empty for Supabase (JWT via JWKS)
AUTH_SERVICE_URL=

# CORS: origins allowed to call API
CORS_ORIGINS=*

# Email (Resend)
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://kvitt.duckdns.org/spotify/callback

# Optional: Scheduler/ops
# ENABLE_OPS_SCHEDULER=false
# LOG_LEVEL=INFO
